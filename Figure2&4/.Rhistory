library(readxl)
library(dplyr)
library(reshape2)
library(pheatmap)
library(RColorBrewer)
library(ggplot2)
library(ggalluvial)
library(tidyr)
library(ggVennDiagram)
library(clusterProfiler)
library(org.Mm.eg.db)
library(enrichplot)
###############################################################################
# 0. Input from code1 and output folders
###############################################################################
code1_root <- "Figure2_code1_whole_brain_results"
code1_tables <- file.path(code1_root, "01_tables")
output_root <- "Figure2_code2_region_results"
dir_tables <- file.path(output_root, "01_tables")
dir_regions <- file.path(output_root, "02_regions")
dir_region_gene <- file.path(output_root, "03_region_gene_expression")
dir_venn <- file.path(output_root, "04_venn")
dir_go <- file.path(output_root, "05_go")
dirs <- c(output_root, dir_tables, dir_regions, dir_region_gene, dir_venn, dir_go)
for (d in dirs) {
if (!dir.exists(d)) dir.create(d, recursive = TRUE)
}
###############################################################################
# 1. Helper functions
###############################################################################
parse_ratio <- function(x) {
sapply(strsplit(x, "/"), function(v) {
as.numeric(v[1]) / as.numeric(v[2])
})
}
convert_gene <- function(gene_symbols) {
bitr(
gene_symbols,
fromType = "SYMBOL",
toType = "ENTREZID",
OrgDb = org.Mm.eg.db
)
}
plot_go_enrichment <- function(gene_symbols, pdf_file, title_prefix, top_n = 10) {
genes_df <- convert_gene(gene_symbols)
if (is.null(genes_df) || nrow(genes_df) == 0) {
message("No valid genes mapped for: ", title_prefix)
return(NULL)
}
ego <- enrichGO(
gene = genes_df$ENTREZID,
OrgDb = org.Mm.eg.db,
ont = "BP",
pAdjustMethod = "BH",
pvalueCutoff = 0.05,
readable = TRUE
)
ego_df <- as.data.frame(ego)
if (is.null(ego_df) || nrow(ego_df) == 0) {
message("No significant GO terms for: ", title_prefix)
return(NULL)
}
ego_df$GeneRatioNum <- parse_ratio(ego_df$GeneRatio)
ego_df <- ego_df[order(ego_df$p.adjust, ego_df$Count, decreasing = c(FALSE, TRUE)), , drop = FALSE]
ego_df <- head(ego_df, top_n)
ego_df$Description <- factor(ego_df$Description, levels = rev(ego_df$Description))
p1 <- ggplot(ego_df, aes(x = Count, y = Description)) +
geom_col(fill = "#4C97C2") +
theme_bw() +
labs(
title = paste0("GO BP Enrichment - ", title_prefix),
x = "Gene Count",
y = NULL
) +
theme(
plot.title = element_text(hjust = 0.5, face = "bold"),
axis.text.y = element_text(size = 9)
)
p2 <- ggplot(ego_df, aes(x = GeneRatioNum, y = Description, size = Count, color = p.adjust)) +
geom_point() +
theme_bw() +
labs(
title = paste0("GO BP Enrichment (Dotplot) - ", title_prefix),
x = "Gene Ratio",
y = NULL
) +
theme(
plot.title = element_text(hjust = 0.5, face = "bold"),
axis.text.y = element_text(size = 9)
)
pdf(pdf_file, width = 8, height = 6)
print(p1)
print(p2)
dev.off()
invisible(ego_df)
}
make_region_expression_annotated <- function(data_matrix, gene_module_metabolite, region) {
gene_list <- unique(gene_module_metabolite$gene_symbol)
rownames(data_matrix) <- paste(
data_matrix$BrainRegion,
data_matrix$mouse_id,
data_matrix$sex,
data_matrix$age,
sep = "_"
)
region_data <- data_matrix[data_matrix$BrainRegion == region, , drop = FALSE]
expression_only <- region_data[, !names(region_data) %in% c("BrainRegion", "mouse_id", "sex", "age"), drop = FALSE]
expression_only <- as.matrix(expression_only)
mode(expression_only) <- "numeric"
expression_matrix <- t(expression_only)
rownames(expression_matrix) <- colnames(expression_only)
expression_matrix <- expression_matrix[rownames(expression_matrix) %in% gene_list, , drop = FALSE]
expression_df <- as.data.frame(expression_matrix)
expression_df$gene_symbol <- rownames(expression_df)
expression_annotated <- expression_df %>%
left_join(gene_module_metabolite, by = "gene_symbol") %>%
relocate(gene_symbol, metabolite, module)
age_info <- region_data[, c("age"), drop = FALSE]
sample_names <- rownames(region_data)
age_info_df <- data.frame(Sample = sample_names, age = age_info$age)
age_info_df$age <- as.numeric(as.character(age_info_df$age))
age_info_df <- age_info_df[order(age_info_df$age), , drop = FALSE]
sorted_samples <- age_info_df$Sample
expression_annotated <- expression_annotated[, c("gene_symbol", "metabolite", "module", sorted_samples)]
list(expression_annotated = expression_annotated, age_info_df = age_info_df)
}
plot_region_flux_heatmap <- function(cluster1_df, reg, outdir) {
df_region <- subset(cluster1_df, region == reg)
if (nrow(df_region) == 0) return(NULL)
mat <- dcast(df_region, module ~ age, value.var = "expression")
rownames(mat) <- mat$module
mat$module <- NULL
wanted_cols <- intersect(c("young", "mid", "old"), colnames(mat))
mat <- mat[, wanted_cols, drop = FALSE]
if (nrow(mat) == 0 || ncol(mat) == 0) return(NULL)
mat_scaled <- t(scale(t(as.matrix(mat))))
annotation_col <- data.frame(age = factor(colnames(mat_scaled), levels = c("young", "mid", "old")))
rownames(annotation_col) <- colnames(mat_scaled)
write.csv(mat_scaled, file.path(outdir, paste0("flux_", reg, ".csv")), quote = FALSE)
pheatmap(
as.matrix(mat),
cluster_rows = TRUE,
cluster_cols = FALSE,
scale = "row",
annotation_col = annotation_col,
color = colorRampPalette(brewer.pal(9, "YlGnBu"))(100),
fontsize = 10,
main = reg,
filename = file.path(outdir, paste0("flux_", reg, ".pdf")),
width = 3,
height = 4.5
)
}
plot_region_cluster_heatmap <- function(mat, reg, outdir) {
initial_res <- pheatmap(
mat,
cluster_rows = TRUE,
cluster_cols = FALSE,
display_numbers = FALSE,
silent = TRUE
)
module_clusters <- cutree(initial_res$tree_row, k = 5)
annotation_row <- data.frame(Cluster = as.factor(module_clusters))
rownames(annotation_row) <- names(module_clusters)
cluster_result <- data.frame(module = names(module_clusters), cluster = module_clusters)
write.csv(cluster_result, file.path(outdir, paste0("clusters_", reg, ".csv")), row.names = FALSE)
heatmap_colors <- colorRampPalette(brewer.pal(9, "YlGnBu"))(100)
pheatmap(
mat,
cluster_rows = TRUE,
scale = "row",
cluster_cols = FALSE,
color = heatmap_colors,
annotation_row = annotation_row,
display_numbers = FALSE,
fontsize = 10,
main = reg,
filename = file.path(outdir, paste0("heatmap_", reg, "_clustered_annotated.pdf")),
width = 4,
height = 4.5
)
module_clusters
}
plot_region_gene_heatmap <- function(expression_annotated, age_info, modules_in_cluster, reg, clus, outdir) {
rownames(age_info) <- age_info$Sample
age_info$age <- as.numeric(as.character(age_info$age))
annotation_col <- data.frame(Age = age_info$age)
rownames(annotation_col) <- age_info$Sample
sub_expr <- expression_annotated[expression_annotated$module %in% modules_in_cluster, , drop = FALSE]
sub_expr <- sub_expr[!duplicated(sub_expr$gene_symbol), , drop = FALSE]
if (nrow(sub_expr) == 0) return(NULL)
sub_expr_matrix <- sub_expr[, !(colnames(sub_expr) %in% c("gene_symbol", "metabolite", "module")), drop = FALSE]
rownames(sub_expr_matrix) <- sub_expr$gene_symbol
expr_with_age <- t(sub_expr_matrix)
expr_with_age <- cbind(expr_with_age, Age = annotation_col[rownames(expr_with_age), "Age"])
expr_with_age_df <- as.data.frame(expr_with_age)
expr_with_age_df$Age <- as.numeric(as.character(expr_with_age_df$Age))
expr_long <- reshape2::melt(expr_with_age_df, id.vars = "Age", variable.name = "Gene", value.name = "Expression")
expr_avg <- aggregate(Expression ~ Gene + Age, data = expr_long, FUN = mean)
expr_wide <- reshape2::dcast(expr_avg, Gene ~ Age, value.var = "Expression")
rownames(expr_wide) <- expr_wide$Gene
expr_wide$Gene <- NULL
sub_expr_matrix <- as.matrix(expr_wide)
sorted_sample_names <- colnames(sub_expr_matrix)
sub_annotation_col <- data.frame(Age = as.numeric(sorted_sample_names))
rownames(sub_annotation_col) <- sorted_sample_names
age_order <- order(sub_annotation_col$Age)
sorted_sample_names <- rownames(sub_annotation_col)[age_order]
sub_expr_matrix <- sub_expr_matrix[, sorted_sample_names, drop = FALSE]
sub_expr_matrix <- sub_expr_matrix[order(rownames(sub_expr_matrix)), , drop = FALSE]
sub_annotation_col <- sub_annotation_col[sorted_sample_names, , drop = FALSE]
sub_annotation_col$Age <- factor(
as.character(sub_annotation_col$Age),
levels = c("3", "12", "15", "18", "21", "26", "28"),
labels = c("3M", "12M", "15M", "18M", "21M", "26M", "28M")
)
sub_annotation_col_colors <- list(
Age = c(
"3M" = "#e41a1c",
"12M" = "#377eb8",
"15M" = "#4daf4a",
"18M" = "#984ea3",
"21M" = "#ff7f00",
"26M" = "#ffff33",
"28M" = "#a65628"
)
)
sub_expr_matrix <- na.omit(sub_expr_matrix)
if (nrow(sub_expr_matrix) == 0) return(NULL)
heatmap_height <- max(3, min(0.1 * nrow(sub_expr_matrix), 25))
pheatmap(
sub_expr_matrix,
cluster_rows = FALSE,
show_colnames = FALSE,
cluster_cols = FALSE,
scale = "row",
annotation_col = sub_annotation_col,
annotation_colors = sub_annotation_col_colors,
fontsize_row = 8,
fontsize = 8,
main = paste0(reg, " - Cluster ", clus),
filename = file.path(outdir, paste0("heatmap_", reg, "_cluster_", clus, ".pdf")),
color = rev(brewer.pal(11, "RdBu")),
width = 3,
height = heatmap_height
)
write.csv(sub_expr_matrix, file.path(outdir, paste0("heatmap_", reg, "_cluster_", clus, ".csv")))
}
plot_region_metabolite_heatmap <- function(met_expr_df_all, gene_module_metabolite, modules_in_cluster, reg, clus, outdir) {
met_expr_df <- met_expr_df_all[met_expr_df_all$region == reg, , drop = FALSE]
met_expr_mean <- met_expr_df %>%
group_by(rNs, age) %>%
summarise(mean_intensity = mean(mean_intensity, na.rm = TRUE), .groups = "drop")
gene_module_metabolite_cluster <- gene_module_metabolite[gene_module_metabolite$module %in% modules_in_cluster, , drop = FALSE]
sub_met_expr_mean <- met_expr_mean[met_expr_mean$rNs %in% gene_module_metabolite_cluster$metabolite, , drop = FALSE]
if (nrow(sub_met_expr_mean) == 0) return(NULL)
heatmap_matrix <- sub_met_expr_mean %>%
pivot_wider(names_from = age, values_from = mean_intensity)
heatmap_matrix <- as.data.frame(heatmap_matrix)
rownames(heatmap_matrix) <- heatmap_matrix$rNs
heatmap_matrix$rNs <- NULL
heatmap_matrix <- as.matrix(heatmap_matrix)
desired_order <- intersect(c("6M", "15M", "21M"), colnames(heatmap_matrix))
if (length(desired_order) > 0) {
heatmap_matrix <- heatmap_matrix[, desired_order, drop = FALSE]
}
scaled_matrix <- t(apply(heatmap_matrix, 1, function(x) {
if (sum(!is.na(x)) >= 2) {
as.numeric(scale(x))
} else {
rep(NA, length(x))
}
}))
rownames(scaled_matrix) <- rownames(heatmap_matrix)
colnames(scaled_matrix) <- colnames(heatmap_matrix)
scaled_matrix <- scaled_matrix[rowSums(!is.na(scaled_matrix)) > 0, , drop = FALSE]
if (nrow(scaled_matrix) == 0) return(NULL)
met_annotation_col <- data.frame(age = colnames(scaled_matrix))
rownames(met_annotation_col) <- colnames(scaled_matrix)
annotation_colors <- list(
age = setNames(
colorRampPalette(c("skyblue", "orange", "green"))(ncol(scaled_matrix)),
colnames(scaled_matrix)
)
)
met_heatmap_height <- max(1, min(0.08 * nrow(scaled_matrix), 25))
pheatmap(
scaled_matrix,
cluster_rows = TRUE,
show_colnames = FALSE,
cluster_cols = FALSE,
annotation_col = met_annotation_col,
annotation_colors = annotation_colors,
fontsize_row = 8,
fontsize = 8,
main = paste0(reg, " - Cluster ", clus),
filename = file.path(outdir, paste0("heatmap_", reg, "_cluster_", clus, "_metabolites.pdf")),
color = rev(brewer.pal(11, "RdBu")),
width = 3,
height = met_heatmap_height
)
write.csv(heatmap_matrix, file.path(outdir, paste0("heatmap_", reg, "_cluster_", clus, "_metabolites.csv")))
}
plot_region_sankey <- function(df_alluvial_labeled, modules_in_cluster, reg, clus, outdir) {
df_alluvial_clu <- df_alluvial_labeled[df_alluvial_labeled$module %in% modules_in_cluster, , drop = FALSE]
if (nrow(df_alluvial_clu) == 0) return(NULL)
p <- ggplot(df_alluvial_clu,
aes(axis1 = metabolite, axis2 = gene_label, axis3 = module)) +
geom_alluvium(aes(fill = metabolite), width = 1/12, alpha = 0.8) +
geom_stratum(width = 1/12, fill = "gray90", color = "black") +
geom_text(stat = "stratum", aes(label = after_stat(stratum)), size = 3, hjust = 0) +
scale_x_discrete(limits = c("Metabolite", "Gene", "Module"), expand = c(.05, .05)) +
theme_minimal() +
ggtitle(paste0(reg, " - Cluster ", clus)) +
theme(axis.text.y = element_blank())
write.csv(df_alluvial_clu, file.path(outdir, paste0("sankey_", reg, "_cluster_", clus, ".csv")), row.names = FALSE)
ggsave(file.path(outdir, paste0("sankey_", reg, "_cluster_", clus, ".pdf")), plot = p, width = 10, height = 10)
}
plot_venn_and_export_groups <- function(gene_csv_files, labels, out_prefix, outdir) {
genes_list <- list()
for (i in seq_along(gene_csv_files)) {
f <- gene_csv_files[i]
if (file.exists(f)) {
tmp <- read.csv(f, row.names = 1, check.names = FALSE)
genes_list[[labels[i]]] <- rownames(tmp)
}
}
if (length(genes_list) < 2) return(NULL)
all_genes <- unique(unlist(genes_list))
presence_matrix <- sapply(genes_list, function(glist) all_genes %in% glist)
rownames(presence_matrix) <- all_genes
presence_df <- as.data.frame(presence_matrix)
presence_df$group <- apply(presence_df, 1, function(x) {
present_clusters <- names(which(x))
if (length(present_clusters) == 0) return("None")
paste(present_clusters, collapse = "_")
})
split_genes <- split(rownames(presence_df), presence_df$group)
gene_group_dir <- file.path(outdir, paste0(out_prefix, "_gene_groups"))
if (!dir.exists(gene_group_dir)) dir.create(gene_group_dir, recursive = TRUE)
for (group_name in names(split_genes)) {
gene_vec <- split_genes[[group_name]]
if (length(gene_vec) > 0) {
write.csv(
data.frame(Gene = gene_vec),
file = file.path(gene_group_dir, paste0("genes_", gsub("[^A-Za-z0-9_]", "_", group_name), ".csv")),
row.names = FALSE
)
}
}
pdf(file.path(outdir, paste0(out_prefix, ".pdf")), width = 8, height = 8)
print(
ggVennDiagram(genes_list, label = "count", label_alpha = 0) +
scale_fill_gradient(low = "#E0F7FA", high = "#56B4E9") +
theme_void(base_size = 18) +
theme(
legend.position = "none",
plot.title = element_text(hjust = 0.5, size = 18, face = "bold"),
plot.margin = margin(10, 10, 10, 10)
) +
ggtitle("Gene Overlap")
)
dev.off()
}
###############################################################################
# 2. Read input data from code1 + raw data
###############################################################################
gene_module_metabolite <- read.csv(file.path(code1_tables, "gene_module_metabolite.csv"), check.names = FALSE)
module_cluster_df <- read.csv(file.path(code1_tables, "module_cluster_df.csv"), check.names = FALSE)
df_alluvial_labeled <- read.csv(file.path(code1_tables, "df_alluvial_labeled.csv"), check.names = FALSE)
write.csv(gene_module_metabolite, file.path(dir_tables, "gene_module_metabolite_from_code1.csv"), row.names = FALSE)
write.csv(module_cluster_df, file.path(dir_tables, "module_cluster_df_from_code1.csv"), row.names = FALSE)
write.csv(df_alluvial_labeled, file.path(dir_tables, "df_alluvial_labeled_from_code1.csv"), row.names = FALSE)
df <- read.csv("./region_flux_csv/all_flux_data_long.csv")
data_matrix <- read.csv("normalized_counts_with_metadata.csv")
met_expr_df_all <- read_excel("sum_normalized_data.xlsx")
met_expr_df_all <- as.data.frame(met_expr_df_all)
###############################################################################
# 3. Region flux based on code1 cluster1
###############################################################################
cluster1_module <- module_cluster_df[module_cluster_df$cluster == 1, "module"]
cluster1_df <- df[df$module %in% cluster1_module, , drop = FALSE]
regions <- c("Hypothalamus", "Thalamus")
for (reg in regions) {
plot_region_flux_heatmap(cluster1_df, reg, dir_regions)
}
###############################################################################
# 4. Region expression matrices
###############################################################################
for (region in regions) {
region_expr_obj <- make_region_expression_annotated(data_matrix, gene_module_metabolite, region)
write.csv(
region_expr_obj$expression_annotated,
file.path(dir_region_gene, paste0("filtered_expression_annotated_", region, ".csv")),
row.names = FALSE
)
write.csv(
region_expr_obj$age_info_df,
file.path(dir_region_gene, paste0("sample_age_info_", region, ".csv")),
row.names = FALSE
)
}
###############################################################################
# 5. Region-specific clustering / gene / metabolite / sankey
###############################################################################
for (reg in regions) {
input_file <- file.path(dir_regions, paste0("flux_", reg, ".csv"))
if (!file.exists(input_file)) next
mat <- read.csv(input_file, row.names = 1, check.names = FALSE)
module_clusters <- plot_region_cluster_heatmap(mat, reg, dir_regions)
expression_annotated <- read.csv(file.path(dir_region_gene, paste0("filtered_expression_annotated_", reg, ".csv")), check.names = FALSE)
age_info <- read.csv(file.path(dir_region_gene, paste0("sample_age_info_", reg, ".csv")), check.names = FALSE)
for (clus in sort(unique(module_clusters))) {
modules_in_cluster <- names(module_clusters[module_clusters == clus])
plot_region_gene_heatmap(expression_annotated, age_info, modules_in_cluster, reg, clus, dir_regions)
plot_region_metabolite_heatmap(met_expr_df_all, gene_module_metabolite, modules_in_cluster, reg, clus, dir_regions)
plot_region_sankey(df_alluvial_labeled, modules_in_cluster, reg, clus, dir_regions)
}
}
###############################################################################
# 6. Region venn
###############################################################################
plot_venn_and_export_groups(
gene_csv_files = c(
file.path(dir_regions, "heatmap_Thalamus_cluster_1.csv"),
file.path(dir_regions, "heatmap_Thalamus_cluster_2.csv"),
file.path(dir_regions, "heatmap_Thalamus_cluster_3.csv"),
file.path(dir_regions, "heatmap_Thalamus_cluster_4.csv"),
file.path(dir_regions, "heatmap_Thalamus_cluster_5.csv")
),
labels = c("Cluster_1", "Cluster_2", "Cluster_3", "Cluster_4", "Cluster_5"),
out_prefix = "venn_clusters_1_to_5_Thalamus",
outdir = dir_venn
)
plot_venn_and_export_groups(
gene_csv_files = c(
file.path(dir_regions, "heatmap_Hypothalamus_cluster_1.csv"),
file.path(dir_regions, "heatmap_Hypothalamus_cluster_2.csv"),
file.path(dir_regions, "heatmap_Hypothalamus_cluster_3.csv"),
file.path(dir_regions, "heatmap_Hypothalamus_cluster_4.csv"),
